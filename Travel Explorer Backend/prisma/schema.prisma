// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js" 
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===================================
// ENUMS
// ===================================

enum Role {
  USER
  ADMIN
  SUPER_ADMIN
}

enum Status {
  Approved
  Pending
  Rejected
}

enum PaymentStatus {
  Completed
  Pending
  Cancelled
}

enum PackageStatus{
  ACTIVE
  INACTIVE
  DRAFT
}

enum BookingStatus{
  Pending
  Confirmed
  Cancelled
  Completed
}

// ===================================
// MODELS
// ===================================

model User {
  id                 String   @id @default(uuid()) @db.Uuid // FIXED: Added @db.Uuid to match foreign keys
  name               String
  email              String   @unique
  age                Int?
  passwordHash       String
  role               Role     @default(USER)
  avatarUrl          String?
  nativeCountry      String?
  isPrivate          Boolean  @default(false)
  emailNotifications Boolean  @default(true)
  createdAt          DateTime? @default(now()) @db.Timestamp @map("created_at")  
  updatedAt          DateTime @updatedAt

  // FIXED: Added missing relation arrays so Prisma can compile back-relations cleanly
  travelPackages     TravelPackage[]
  bookings           Booking[]
  favorites          Favorite[]
  visits             DestinationVisit[]
  uploadedImages     GalleryImage[]     @relation("UploadedImages")
  reviewedImages     GalleryImage[]     @relation("ReviewedImages")
  refreshTokenHash   String?

  @@map("users") // Added mapping for safety

}

model CountryProfile {
  alpha3Code            String        @id @db.Char(3) @map("alpha_3_code")
  alpha2Code            String?       @db.Char(2) @map("alpha_2_code")
  commonName            String?       @db.VarChar(100) @map("common_name")
  officialName          String?       @db.VarChar(150) @map("official_name")
  continent             String?       @db.VarChar(50)
  population            BigInt?
  areaSqKm              Decimal?      @db.Decimal(12, 2) @map("area_sq_km")
  capitals              Json? // JSONB representation
  languages             String[] // TEXT[] mapping
  timezones             String[] // TEXT[] mapping
  flagDescription       String?       @map("flag_description")
  flagUrlPng            String?       @map("flag_url_png")
  flagUrlSvg            String?       @map("flag_url_svg")
  currencies            Json? // JSONB representation
  googleMapsUrl         String?       @map("google_maps_url")
  openStreetMapsUrl     String?       @map("open_street_maps_url")
  tagline               String?       @db.VarChar(255)
  costOfLivingPerDayUsd Decimal?      @db.Decimal(10, 2) @map("cost_of_living_per_day_usd")
  budgetLevel           String?       @db.VarChar(20) @map("budget_level")
  infrastructureRating  Decimal?      @db.Decimal(3, 1) @map("infrastructure_rating")
  safetyScore           Decimal?      @db.Decimal(3, 1) @map("safety_score")
  climate               String?       @db.VarChar(100)
  topIndustry           String?       @db.VarChar(100) @map("top_industry")
  tourismSpeciality     String[]      @default([])     @map("tourism_speciality")
  visaDifficulty        String?       @db.VarChar(50) @map("visa_difficulty")
  bestTimeToVisit       String?       @db.VarChar(100) @map("best_time_to_visit")
  transportOptions      String[]      @default([])     @map("transport_options")
  touristFriendliness   Decimal?      @db.Decimal(3, 1) @map("tourist_friendliness")
  featuredAttraction    Json?         @map("featured_attraction")


  @@map("country_profiles")
}

model Destination {
  id                 String             @id @default(uuid()) @db.Uuid
  name               String?            @db.VarChar(100)
  region             String?            @db.VarChar(100)
  lat                Decimal?           @db.Decimal(9, 6)
  lng                Decimal?           @db.Decimal(9, 6)
  shortDescription   String?            @db.VarChar(255) @map("short_description")
  description        String?            @db.Text
  longDescription    String?            @db.Text @map("long_description")
  didYouKnow         String?            @db.Text @map("did_you_know")
  budgetLevel        String?            @db.VarChar(20) @map("budget_level")
  currency           String?            @db.Char(3)
  visaDifficulty     String?            @db.VarChar(50) @map("visa_difficulty")
  bestTimeToVisit    String?            @db.VarChar(255) @map("best_time_to_visit")
  averageTemperature String?            @db.VarChar(20) @map("average_temperature")
  colorHex           String?            @db.VarChar(7) @map("color_hex")
  highlights         String[]
  famousFor          String[]           @map("famous_for")
  languages          String[]
  topAttractions     Json?              @map("top_attractions")
  createdAt          DateTime? @default(now()) @db.Timestamp @map("created_at")  
  travelPackages     TravelPackage[]
  favorites          Favorite[]
  visits             DestinationVisit[]
  galleryImages      GalleryImage[]

  @@map("destinations")
}

model TravelPackage {
  id              String       @id @default(uuid()) @db.Uuid
  destinationId   String?      @db.Uuid @map("destination_id")
  createdBy       String?      @db.Uuid @map("created_by")
  name            String?      @db.VarChar(255)
  description     String?      @db.Text
  from            String?      @db.Text
  startDate       DateTime?    @db.Date @map("start_date")
  endDate         DateTime?    @db.Date @map("end_date")
  originalPrice   Decimal?     @db.Decimal(10, 2) @map("original_price")
  discountedPrice Decimal?     @db.Decimal(10, 2) @map("discounted_price")
  hasOffer        Boolean?     @default(false) @map("has_offer")
  offerValue       Decimal?     @db.Decimal(10, 2) @map("offer_value")
  maxTravelers    Int?         @map("max_travelers")
  availableSlots  Int?         @map("available_slots")
  status          PackageStatus? @default(ACTIVE)     
  createdAt       DateTime? @default(now()) @db.Timestamp @map("created_at")  
  updatedAt       DateTime?    @db.Timestamp @map("updated_at")

  destination     Destination? @relation(fields: [destinationId], references: [id])
  creator         User?        @relation(fields: [createdBy], references: [id])
  bookings        Booking[]

  @@map("travel_packages")
}

model Booking {
  id               String         @id @default(uuid()) @db.Uuid
  userId           String?        @db.Uuid @map("user_id")
  packageId        String?        @db.Uuid @map("package_id")

  travelerCount    Int?           @map("traveler_count")
  travelers        Json?          @map("travelers")

  totalCost        Decimal?       @db.Decimal(10, 2) @map("total_cost")

  paymentStatus    PaymentStatus? @default(Pending) @map("payment_status")
  bookingStatus    BookingStatus? @default(Pending) @map("booking_status")

  bookedAt         DateTime?      @default(now()) @db.Timestamp @map("booked_at")
  startDate        DateTime?      @db.Date @map("start_date")
  endDate          DateTime?      @db.Date @map("end_date")

  paymentOrderId   String?        @map("payment_order_id")
  paymentId        String?        @map("payment_id")
  paymentSignature String?        @map("payment_signature")

  user             User?          @relation(fields: [userId], references: [id])
  package          TravelPackage? @relation(fields: [packageId], references: [id])

  @@map("bookings")
}

model Favorite {
  id            String      @id @default(uuid()) @db.Uuid
  userId        String      @db.Uuid @map("user_id")
  destinationId String      @db.Uuid @map("destination_id")
  createdAt     DateTime    @default(now()) @db.Timestamp @map("created_at")

  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  destination   Destination @relation(fields: [destinationId], references: [id], onDelete: Cascade)

  @@unique([userId, destinationId])
  @@map("favorites")
}

model DestinationVisit {
  id            String       @id @default(uuid()) @db.Uuid
  userId        String?      @db.Uuid @map("user_id")
  destinationId String?      @db.Uuid @map("destination_id")
  visitedAt     DateTime?    @db.Timestamp @map("visited_at")

  user          User?        @relation(fields: [userId], references: [id])
  destination   Destination? @relation(fields: [destinationId], references: [id])

  @@map("destination_visits")
  @@unique([userId, destinationId])
}

model GalleryImage {
  id            String       @id @default(uuid()) @db.Uuid
  uploadedBy    String?      @db.Uuid @map("uploaded_by")
  destinationId String?      @db.Uuid @map("destination_id")
  imageUrl      String?      @db.Text @map("image_url")
  caption       String?      @db.Text
  status        Status?
  reviewedBy    String?      @db.Uuid @map("reviewed_by")
  reviewedAt    DateTime?    @db.Timestamp @map("reviewed_at")
  createdAt     DateTime? @default(now()) @db.Timestamp @map("created_at")
  uploader      User?        @relation("UploadedImages", fields: [uploadedBy], references: [id])
  reviewer      User?        @relation("ReviewedImages", fields: [reviewedBy], references: [id])
  destination   Destination? @relation(fields: [destinationId], references: [id])

  @@map("gallery_images")
}